<Window x:Class="EventsWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EventsWPF"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="MainWindow">

    <Window.Resources>
        <DrawingBrush x:Key="Tile" Stretch="None" TileMode="Tile" Viewport="0,0,50,50" ViewportUnits="Absolute">
            <!--Tiling checkered pattern-->
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="BlanchedAlmond">
                        <!--Draw square-->
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,50,50"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="DarkGoldenrod">
                        <!--draw border-->
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="1,1,48,2"/>
                                <RectangleGeometry Rect="1,3,2,46"/>
                                <RectangleGeometry Rect="47,3,2,46"/>
                                <RectangleGeometry Rect="3,47,44,2"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <DrawingBrush x:Key="KingSquare" Stretch="None" TileMode="Tile" Viewport="0,0,50,50" ViewportUnits="Absolute">
            <!--Tiling king square pattern-->
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="BlanchedAlmond">
                        <!--Draw rect-->
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,50,50"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="DarkGoldenrod">
                        <!--draw spiral pattern-->
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="1,1,46,2"/>
                                <RectangleGeometry Rect="1,3,2,46"/>
                                <RectangleGeometry Rect="47,1,2,46"/>
                                <RectangleGeometry Rect="3,47,46,2"/>

                                <RectangleGeometry Rect="3,5,38,2"/>
                                <RectangleGeometry Rect="43,3,2,38"/>
                                <RectangleGeometry Rect="5,9,2,38"/>
                                <RectangleGeometry Rect="9,43,38,2"/>

                                <RectangleGeometry Rect="7,9,30,2"/>
                                <RectangleGeometry Rect="39,7,2,30"/>
                                <RectangleGeometry Rect="9,13,2,30"/>
                                <RectangleGeometry Rect="13,39,30,2"/>

                                <RectangleGeometry Rect="11,35,22,2"/>
                                <RectangleGeometry Rect="13,11,2,22"/>
                                <RectangleGeometry Rect="35,17,2,22"/>
                                <RectangleGeometry Rect="17,13,22,2"/>

                                <RectangleGeometry Rect="15,31,14,2"/>
                                <RectangleGeometry Rect="31,21,2,14"/>
                                <RectangleGeometry Rect="17,15,2,14"/>
                                <RectangleGeometry Rect="21,17,14,2"/>

                                <RectangleGeometry Rect="19,21,6,2"/>
                                <RectangleGeometry Rect="27,19,2,6"/>
                                <RectangleGeometry Rect="21,25,2,6"/>
                                <RectangleGeometry Rect="25,27,6,2"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <DrawingBrush x:Key="Board">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource Tile}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,550,550" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource KingSquare}">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,50,50"/>
                                <RectangleGeometry Rect="500,0,50,50"/>
                                <RectangleGeometry Rect="0,500,50,50"/>
                                <RectangleGeometry Rect="500,500,50,50"/>
                                <RectangleGeometry Rect="250,250,50,50"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <DrawingBrush x:Key="BlackPiece">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="DarkSlateGray">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,0,0"/>
                                <RectangleGeometry Rect="0,36,40,4"/>
                                <RectangleGeometry Rect="4,32,32,4"/>
                                <RectangleGeometry Rect="9,8,22,24"/>
                                <RectangleGeometry Rect="12,4,16,4"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="Black">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="1,37,38,2"/>
                                <RectangleGeometry Rect="5,33,30,3"/>
                                <RectangleGeometry Rect="10,9,20,23"/>
                                <RectangleGeometry Rect="13,5,14,3"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <DrawingBrush x:Key="WhitePiece">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="DarkSlateGray">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,0,0"/>
                                <RectangleGeometry Rect="0,36,40,4"/>
                                <RectangleGeometry Rect="4,32,32,4"/>
                                <RectangleGeometry Rect="9,8,22,24"/>
                                <RectangleGeometry Rect="12,4,16,4"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="1,37,38,2"/>
                                <RectangleGeometry Rect="5,33,30,3"/>
                                <RectangleGeometry Rect="10,9,20,23"/>
                                <RectangleGeometry Rect="13,5,14,3"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <DrawingBrush x:Key="King">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="DarkSlateGray">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,36,40,4"/>
                                <RectangleGeometry Rect="3,32,34,4"/>
                                <RectangleGeometry Rect="8,12,24,20"/>
                                <RectangleGeometry Rect="4,6,32,6"/>
                                <RectangleGeometry Rect="4,0,8,6"/>
                                <RectangleGeometry Rect="16,0,8,6"/>
                                <RectangleGeometry Rect="28,0,8,6"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="1,37,38,2"/>
                                <RectangleGeometry Rect="4,33,32,3"/>
                                <RectangleGeometry Rect="9,12,22,20"/>
                                <RectangleGeometry Rect="12,7,4,5"/>
                                <RectangleGeometry Rect="24,7,4,5"/>
                                <RectangleGeometry Rect="5,1,6,10"/>
                                <RectangleGeometry Rect="17,1,6,10"/>
                                <RectangleGeometry Rect="29,1,6,10"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <DrawingBrush x:Key="TargetSquare">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="DimGray">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,2,38"/>
                                <RectangleGeometry Rect="2,0,38,2"/>
                                <RectangleGeometry Rect="38,2,2,38"/>
                                <RectangleGeometry Rect="0,38,38,2"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <Style x:Key="PieceStyle" TargetType="{x:Type Canvas}">
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Type}" Value="{x:Static local:PieceType.BlackPiece}"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Background" Value="{StaticResource BlackPiece}"/>
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Type}" Value="{x:Static local:PieceType.WhitePiece}"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Background" Value="{StaticResource WhitePiece}"/>
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Type}" Value="{x:Static local:PieceType.WhiteKing}"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Background" Value="{StaticResource King}"/>
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Type}" Value="{x:Static local:PieceType.TargetSquare}"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Background" Value="{StaticResource TargetSquare}"/>
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Log" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Background">
                <Setter.Value>
                    <DrawingBrush Viewport="0,0,150,400" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="BlanchedAlmond">
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <RectangleGeometry Rect="0,0,150,400"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="DarkGoldenrod">
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <RectangleGeometry Rect="1,1,146,2"/>
                                            <RectangleGeometry Rect="1,3,2,396"/>
                                            <RectangleGeometry Rect="3,397,146,2"/>
                                            <RectangleGeometry Rect="147,1,2,396"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BackButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"/>
                            <ContentPresenter Name="Content"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="DarkGoldenrod"/>
                                <Setter Property="ContentPresenter.Content" TargetName="Content">
                                    <Setter.Value>
                                        <TextBlock Text="Undo" FontSize="24" FontWeight="SemiBold" Foreground="BlanchedAlmond" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="ContentPresenter.Content" TargetName="Content">
                                    <Setter.Value>
                                        <TextBlock Text="Undo" FontSize="24" FontWeight="SemiBold" Foreground="DarkGoldenrod" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <DrawingBrush Viewport="0,0,150,50" ViewportUnits="Absolute">
                                            <DrawingBrush.Drawing>
                                                <DrawingGroup>
                                                    <GeometryDrawing Brush="BlanchedAlmond">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="0,0,150,50"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                    <GeometryDrawing Brush="DarkGoldenrod">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="1,1,145,3"/>
                                                                <RectangleGeometry Rect="1,4,3,45"/>
                                                                <RectangleGeometry Rect="4,46,145,3"/>
                                                                <RectangleGeometry Rect="146,1,3,45"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                </DrawingGroup>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="ContentPresenter.Content" TargetName="Content">
                                    <Setter.Value>
                                        <TextBlock Text="Undo" FontSize="24" Foreground="DarkGoldenrod" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <DrawingBrush Viewport="0,0,150,50" ViewportUnits="Absolute">
                                            <DrawingBrush.Drawing>
                                                <DrawingGroup>
                                                    <GeometryDrawing Brush="BlanchedAlmond">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="0,0,150,50"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                    <GeometryDrawing Brush="DarkGoldenrod">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="1,1,146,2"/>
                                                                <RectangleGeometry Rect="1,3,2,46"/>
                                                                <RectangleGeometry Rect="3,47,146,2"/>
                                                                <RectangleGeometry Rect="147,1,2,46"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                </DrawingGroup>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"/>
                            <ContentPresenter Name="Content"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="DarkGoldenrod"/>
                                <Setter Property="ContentPresenter.Content" TargetName="Content">
                                    <Setter.Value>
                                        <TextBlock Text="New Game" FontSize="24" FontWeight="SemiBold" Foreground="BlanchedAlmond" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="ContentPresenter.Content" TargetName="Content">
                                    <Setter.Value>
                                        <TextBlock Text="New Game" FontSize="24" FontWeight="SemiBold" Foreground="DarkGoldenrod" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <DrawingBrush Viewport="0,0,150,50" ViewportUnits="Absolute">
                                            <DrawingBrush.Drawing>
                                                <DrawingGroup>
                                                    <GeometryDrawing Brush="BlanchedAlmond">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="0,0,150,50"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                    <GeometryDrawing Brush="DarkGoldenrod">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="1,1,145,3"/>
                                                                <RectangleGeometry Rect="1,4,3,45"/>
                                                                <RectangleGeometry Rect="4,46,145,3"/>
                                                                <RectangleGeometry Rect="146,1,3,45"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                </DrawingGroup>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="ContentPresenter.Content" TargetName="Content">
                                    <Setter.Value>
                                        <TextBlock Text="New Game" FontSize="24" Foreground="DarkGoldenrod" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <DrawingBrush Viewport="0,0,150,50" ViewportUnits="Absolute">
                                            <DrawingBrush.Drawing>
                                                <DrawingGroup>
                                                    <GeometryDrawing Brush="BlanchedAlmond">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="0,0,150,50"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                    <GeometryDrawing Brush="DarkGoldenrod">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <RectangleGeometry Rect="1,1,146,2"/>
                                                                <RectangleGeometry Rect="1,3,2,46"/>
                                                                <RectangleGeometry Rect="3,47,146,2"/>
                                                                <RectangleGeometry Rect="147,1,2,46"/>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                </DrawingGroup>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Win" TargetType="Canvas">
            <Style.Triggers>
                <DataTrigger Binding="{Binding GameWon}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <DrawingBrush>
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="Azure">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,100,100"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Path=GameWon}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <DrawingBrush>
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="Red">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,100,100"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Viewbox>
        <StackPanel Background="BlanchedAlmond" Orientation="Horizontal">
            <Viewbox Height="550" Width="550">
                <Grid>
                    <Canvas Style="{Binding Win}" Panel.ZIndex="10" Width="9" Height="5"/>
                    <ItemsControl Panel.ZIndex="1" Name="Board" Grid.Column="0">
                        <!--Make Board object-->
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Height="11" Width="11" Background="{StaticResource Board}"/>
                                <!--Draw out board-->
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="1" Height="1">
                                    <Canvas Width="0.8" Height="0.8" Style="{StaticResource PieceStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding Pos.X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Pos.Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Grid>
            </Viewbox>
            <StackPanel Height="550" Width="200">
                <ListBox Name="Log_" Height="400" Width="150" Style="{StaticResource Log}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Record}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Height="50" Width="150" Click="BackButtonClick" Style="{StaticResource BackButton}"/>
                <Grid Height="50"/>
                <Button Height="50" Width="150" Click="ResetButtonClick" Style="{StaticResource ResetButton}"/>
            </StackPanel>
        </StackPanel>
    </Viewbox>
</Window>
